name = "victoriametrics"
version = "@VERSION@"
arch = "@ARCH@"
maintainer = "ArtifactX Packages <packages@artifactx.local>"
description = "VictoriaMetrics single-node community edition"
license = "Apache-2.0"
section = "database"
group = "Applications/Databases"
depends = []
config_files = []

[[files]]
source = "@BINARY_PATH@"
dest = "/usr/local/bin/victoria-metrics-prod"
mode = "0755"

[[files]]
source = "@SERVICE_PATH@"
dest = "/usr/lib/systemd/system/victoriametrics.service"
mode = "0644"

[scripts]
postinst = "@POSTINST_PATH@"
postrm = "@POSTRM_PATH@"
